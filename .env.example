# ============================================
# TELEGRAM BOT
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================
# SUPABASE (ваш развернутый сервер)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ============================================
# OPENAI
# ============================================
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# N8N WEBHOOKS (5 отдельных для каждого типа)
# Формат: http://YOUR_SERVER_IP:5678/webhook/NAME
# ============================================
N8N_WEBHOOK_OSEBE=http://YOUR_SERVER_IP:5678/webhook/pptbot-osebe
N8N_WEBHOOK_POST=http://YOUR_SERVER_IP:5678/webhook/pptbot-post
N8N_WEBHOOK_BLUEBUTT=http://YOUR_SERVER_IP:5678/webhook/pptbot-bluebutt
N8N_WEBHOOK_ANONS=http://YOUR_SERVER_IP:5678/webhook/pptbot-anons
N8N_WEBHOOK_PRODAJ=http://YOUR_SERVER_IP:5678/webhook/pptbot-prodaj

# ============================================
# WEBHOOK SERVER (порт для приёма ответов от n8n)
# ============================================
WEBHOOK_PORT=8080
